node_modules/
.DS_Store
*.log

# Secrets / local env — never commit
.env
.env.*
!.env.example
web/.env
web/.env.local
web/.env.*.local
!web/.env.example

# Next.js
web/.next/
web/out/
web/.pages-stash/
