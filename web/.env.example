# Documentation only for local development.
# The hosted GitHub Pages site does not use env for AI.
#
# Local generation uses Settings in the browser (localStorage).
# Optional: copy nothing — defaults live in web/src/lib/ai/defaults.ts
#
# For Pages CI only (set in GitHub Actions, not in this file):
# NEXT_PUBLIC_STATIC_SITE=true
# NEXT_PUBLIC_BASE_PATH=/your-repo-name
